{
  "name": "@examplehr/time-off-service",
  "private": true,
  "version": "0.0.0",
  "description": "Time-off microservice (port 3000).",
  "license": "UNLICENSED",
  "main": "dist/app.module.js",
  "types": "dist/app.module.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --passWithNoTests --selectProjects unit",
    "test:integration": "jest --passWithNoTests --selectProjects integration",
    "test:cov": "jest --coverage --passWithNoTests",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier -w ."
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.12.0",
    "better-sqlite3": "^12.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.26"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.6.0",
    "supertest": "^7.0.0",
    "ts-node": "^10.9.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "eslintConfig": {
    "root": true,
    "env": {
      "node": true,
      "es2022": true,
      "jest": true
    },
    "parser": "@typescript-eslint/parser",
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module",
      "project": ["./tsconfig.json"]
    },
    "plugins": ["@typescript-eslint"],
    "extends": ["eslint:recommended", "plugin:@typescript-eslint/recommended"],
    "rules": {
      "@typescript-eslint/no-unused-vars": ["error", { "argsIgnorePattern": "^_", "varsIgnorePattern": "^_" }]
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "trailingComma": "all",
    "printWidth": 100
  }
}
